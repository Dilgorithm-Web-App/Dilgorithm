GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
# SMTP — Mailtrap Email Testing (https://mailtrap.io)
# Host: sandbox.smtp.mailtrap.io | Ports: 25, 465, 587, 2525 | Auth: PLAIN, LOGIN, CRAM-MD5
# STARTTLS is optional on all ports; below uses 2525 + TLS (recommended for Django).
# For port 465: EMAIL_PORT=465, EMAIL_USE_SSL=true, EMAIL_USE_TLS=false
# Paste your inbox SMTP username/password from Mailtrap (never commit real values).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-mailtrap-smtp-username
EMAIL_HOST_PASSWORD=your-mailtrap-smtp-password
DEFAULT_FROM_EMAIL=no-reply@dilgorithm.local
